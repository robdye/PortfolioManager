# OpenAI Configuration
# Use EITHER standard OpenAI OR Azure OpenAI (not both)

# Option 1: Standard OpenAI API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Option 2: Azure OpenAI (takes precedence if AZURE_OPENAI_API_KEY is set)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# MCP Tooling Configuration
BEARER_TOKEN=

# ── Portfolio MCP Server Endpoints ──
# Your existing MCP server on Azure Container Apps
MCP_FINNHUB_ENDPOINT=https://<YOUR_MCP_APP>.azurecontainerapps.io/finnhub/mcp
MCP_CRM_ENDPOINT=https://<YOUR_MCP_APP>.azurecontainerapps.io/crm/mcp
MCP_PORTFOLIO_ENDPOINT=https://<YOUR_MCP_APP>.azurecontainerapps.io/portfolio/mcp

# ── Manager Configuration ──
MANAGER_EMAIL=<YOUR_MANAGER_EMAIL>
MANAGER_NAME=Robert Dye

# ── Portfolio Monitoring ──
# Threshold for significant price moves (percentage)
PRICE_CHANGE_THRESHOLD=2.0
# Threshold for significant FX rate moves (percentage)
FX_CHANGE_THRESHOLD=1.0

# ── Scheduler ──
# All scheduled tasks are API-driven. Set a secret for the scheduler endpoints.
SCHEDULED_SECRET=

# ── Observability ──
ENABLE_A365_OBSERVABILITY_EXPORTER=false
Use_Custom_Resolver=true
A365_OBSERVABILITY_LOG_LEVEL=

# ── Environment Settings ──
NODE_ENV=development
HOST=127.0.0.1

# ── Telemetry ──
DEBUG=agents:*

# ── Agentic Auth ──
USE_AGENTIC_AUTH=false

# ── Service Connection ──
connections__service_connection__settings__clientId=
connections__service_connection__settings__clientSecret=
connections__service_connection__settings__tenantId=

connectionsMap__0__serviceUrl=*
connectionsMap__0__connection=service_connection

# ── Agentic Authentication ──
agentic_type=agentic
agentic_altBlueprintConnectionName=service_connection
agentic_scopes=ea9ffc3e-8a23-4a7d-836d-234d7c7565c1/.default
