{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "workerUrl": {
      "type": "string",
      "defaultValue": "https://portfolio-manager-worker.jollysand-88b78b02.eastus.azurecontainerapps.io"
    },
    "scheduledSecret": {
      "type": "securestring",
      "defaultValue": "portfolio-scheduler-2026"
    }
  },
  "variables": {
    "envId": "/subscriptions/afae635b-b494-4d71-b5b8-91d2d6a61860/resourceGroups/rg-portfolio-agent/providers/Microsoft.App/managedEnvironments/portfolio-agent-mcp-cae",
    "jobs": [
      { "name": "pm-job-workday-init", "cron": "30 8 * * *",        "endpoint": "/api/scheduled/workday/init", "timeout": 300 },
      { "name": "pm-job-briefing",     "cron": "0 9 * * *",         "endpoint": "/api/scheduled/briefing",     "timeout": 300 },
      { "name": "pm-job-monitor",      "cron": "*/5 * * * *",       "endpoint": "/api/scheduled/monitor",      "timeout": 120 },
      { "name": "pm-job-workday-cycle","cron": "*/30 * * * *",      "endpoint": "/api/scheduled/workday/cycle", "timeout": 180 },
      { "name": "pm-job-decision",     "cron": "*/30 * * * *",      "endpoint": "/api/scheduled/decision",     "timeout": 180 },
      { "name": "pm-job-fx",           "cron": "*/15 * * * *",      "endpoint": "/api/scheduled/fx",           "timeout": 120 },
      { "name": "pm-job-compliance",   "cron": "0 8 * * 1",         "endpoint": "/api/scheduled/compliance",   "timeout": 300 },
      { "name": "pm-job-earnings",     "cron": "0 7 * * *",         "endpoint": "/api/scheduled/earnings",     "timeout": 180 },
      { "name": "pm-job-challenge",    "cron": "0 16 * * 5",        "endpoint": "/api/scheduled/challenge",    "timeout": 180 },
      { "name": "pm-job-commentary",   "cron": "0 9 1 * *",         "endpoint": "/api/scheduled/commentary",   "timeout": 300 },
      { "name": "pm-job-workday-end",  "cron": "0 17 * * *",        "endpoint": "/api/scheduled/workday/end",  "timeout": 300 }
    ]
  },
  "resources": [
    {
      "copy": {
        "name": "jobCopy",
        "count": "[length(variables('jobs'))]"
      },
      "type": "Microsoft.App/jobs",
      "apiVersion": "2024-03-01",
      "name": "[variables('jobs')[copyIndex()].name]",
      "location": "eastus",
      "properties": {
        "environmentId": "[variables('envId')]",
        "configuration": {
          "triggerType": "Schedule",
          "scheduleTriggerConfig": {
            "cronExpression": "[variables('jobs')[copyIndex()].cron]"
          },
          "replicaTimeout": "[variables('jobs')[copyIndex()].timeout]",
          "replicaRetryLimit": 1
        },
        "template": {
          "containers": [
            {
              "name": "scheduler",
              "image": "mcr.microsoft.com/cbl-mariner/base/core:2.0",
              "resources": {
                "cpu": 0.25,
                "memory": "0.5Gi"
              },
              "command": ["/bin/bash", "-c"],
              "args": ["[concat('curl -sf -X POST -H \"x-scheduled-secret: ', parameters('scheduledSecret'), '\" -H \"Content-Type: application/json\" ', parameters('workerUrl'), variables('jobs')[copyIndex()].endpoint, ' && echo OK')]"]
            }
          ]
        }
      }
    }
  ]
}
