{
  "properties": {
    "managedEnvironmentId": "[parameters('managedEnvironmentId')]",
    "configuration": {
      "ingress": {
        "external": true,
        "targetPort": 3978
      },
      "registries": [
        {
          "server": "[parameters('containerRegistryServer')]",
          "identity": "system"
        }
      ]
    },
    "template": {
      "containers": [
        {
          "name": "portfolio-manager-worker",
          "image": "[parameters('containerImage')]",
          "resources": {
            "cpu": 0.5,
            "memory": "1Gi"
          },
          "env": [
            { "name": "NODE_ENV", "value": "production" },
            { "name": "PORT", "value": "3978" },
            { "name": "HOST", "value": "0.0.0.0" },
            { "name": "MANAGER_EMAIL", "value": "[parameters('managerEmail')]" },
            { "name": "MANAGER_NAME", "value": "[parameters('managerName')]" },
            { "name": "PRICE_CHANGE_THRESHOLD", "value": "2.0" },
            { "name": "FX_CHANGE_THRESHOLD", "value": "1.0" },
            { "name": "MCP_FINNHUB_ENDPOINT", "value": "[concat(parameters('mcpServerUrl'), '/finnhub/mcp')]" },
            { "name": "MCP_CRM_ENDPOINT", "value": "[concat(parameters('mcpServerUrl'), '/crm/mcp')]" },
            { "name": "MCP_PORTFOLIO_ENDPOINT", "value": "[concat(parameters('mcpServerUrl'), '/portfolio/mcp')]" },
            { "name": "USE_AGENTIC_AUTH", "value": "true" },
            { "name": "connections__service_connection__settings__clientId", "value": "[parameters('agentBlueprintId')]" },
            { "name": "connections__service_connection__settings__clientSecret", "secretRef": "sp-client-secret" },
            { "name": "connections__service_connection__settings__tenantId", "value": "[parameters('tenantId')]" },
            { "name": "connectionsMap__0__serviceUrl", "value": "*" },
            { "name": "connectionsMap__0__connection", "value": "service_connection" },
            { "name": "agentic_type", "value": "agentic" },
            { "name": "agentic_altBlueprintConnectionName", "value": "service_connection" },
            { "name": "agentic_scopes", "value": "https://graph.microsoft.com/.default" },
            { "name": "agent_id", "value": "[parameters('agentBlueprintId')]" },
            { "name": "CHANNEL_WEBHOOK_URL", "secretRef": "channel-webhook-url" },
            { "name": "SCHEDULED_SECRET", "secretRef": "scheduler-secret" }
          ],
          "probes": [
            {
              "type": "startup",
              "httpGet": {
                "path": "/api/health",
                "port": 3978
              },
              "initialDelaySeconds": 15,
              "periodSeconds": 10,
              "failureThreshold": 30,
              "timeoutSeconds": 5
            },
            {
              "type": "liveness",
              "httpGet": {
                "path": "/api/health",
                "port": 3978
              },
              "initialDelaySeconds": 60,
              "periodSeconds": 30,
              "failureThreshold": 3,
              "timeoutSeconds": 5
            }
          ]
        }
      ],
      "scale": {
        "minReplicas": 1,
        "maxReplicas": 1
      }
    }
  },
  "location": "eastus"
}
