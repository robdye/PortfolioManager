{
  "name": "portfolio-manager-digital-worker",
  "version": "1.0.0",
  "main": "dist/index.js",
  "type": "commonjs",
  "description": "Agent 365 Digital Worker - Portfolio Manager persona with morning briefings, portfolio monitoring, and meeting summaries",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --exec ts-node src/index.ts",
    "test-tool": "agentsplayground",
    "build": "tsc && node -e \"const fs=require('fs'),p=require('path');const vd=p.join('dist','voice');fs.mkdirSync(vd,{recursive:true});fs.copyFileSync(p.join('src','voice','voice.html'),p.join(vd,'voice.html'));fs.copyFileSync(p.join('src','mission-control.html'),p.join('dist','mission-control.html'));console.log('Copied voice.html + mission-control.html')\"",
    "clean": "rimraf dist node_modules package-lock.json",
    "install:clean": "npm run clean && npm install",
    "test": "vitest run"
  },
  "license": "MIT",
  "dependencies": {
    "@azure-rest/ai-content-safety": "^1.0.1",
    "@azure/cosmos": "^4.9.3",
    "@azure/data-tables": "^13.3.2",
    "@azure/identity": "^4.13.1",
    "@azure/keyvault-secrets": "^4.11.1",
    "@azure/monitor-opentelemetry-exporter": "^1.0.0-beta.32",
    "@azure/service-bus": "^7.9.5",
    "@microsoft/agents-a365-notifications": "^0.1.0-preview.30",
    "@microsoft/agents-a365-observability": "^0.1.0-preview.30",
    "@microsoft/agents-a365-observability-extensions-openai": "^0.1.0-preview.30",
    "@microsoft/agents-a365-observability-hosting": "^0.1.0-preview.64",
    "@microsoft/agents-a365-runtime": "^0.1.0-preview.30",
    "@microsoft/agents-a365-tooling": "^0.1.0-preview.119",
    "@microsoft/agents-a365-tooling-extensions-openai": "^0.1.0-preview.119",
    "@microsoft/agents-activity": "^1.2.2",
    "@microsoft/agents-hosting": "^1.2.2",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@openai/agents": "^0.1.11",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.215.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@types/ws": "^8.18.1",
    "docx": "^9.5.0",
    "dotenv": "^17.2.2",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "openai": "^4.77.0",
    "pptxgenjs": "^3.12.0",
    "redis": "^5.12.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@microsoft/m365agentsplayground": "^0.2.18",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "nodemon": "^3.1.10",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@openai/agents-core": "$@openai/agents",
    "@openai/agents-openai": "$@openai/agents",
    "openai": "$openai"
  }
}
