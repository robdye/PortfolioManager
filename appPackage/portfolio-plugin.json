{
    "$schema": "https://developer.microsoft.com/json-schemas/copilot/plugin/v2.4/schema.json",
    "schema_version": "v2.4",
    "name_for_human": "Portfolio CRUD",
    "description_for_human": "Read, update, add, and delete portfolio holdings in Dataverse with compliance tracking, FX exposure, and revenue attribution",
    "namespace": "portfoliocrud",
    "functions": [
        {
            "name": "read-portfolio",
            "description": "Read portfolio holdings from Dataverse. Optional filter: 'active', 'prospects', or a ticker symbol.",
            "parameters": { "type": "object", "properties": { "filter": { "type": "string", "description": "Optional: 'active', 'prospects', or a ticker symbol" } } }
        },
        {
            "name": "update-portfolio-holding",
            "description": "Update an existing portfolio holding by ticker. Specify only fields to change.",
            "parameters": { "type": "object", "properties": { "ticker": { "type": "string" }, "shares": { "type": "string" }, "costPerShare": { "type": "string" }, "totalCost": { "type": "string" }, "sector": { "type": "string" }, "holdingType": { "type": "string" }, "website": { "type": "string" }, "mediaPress": { "type": "string" }, "currencyExposure": { "type": "string" }, "fxHedged": { "type": "string" }, "revenueAttributed": { "type": "string" }, "marginPercent": { "type": "string" } }, "required": ["ticker"] }
        },
        {
            "name": "add-portfolio-holding",
            "description": "Add a new holding to the portfolio. Requires company name and ticker.",
            "parameters": { "type": "object", "properties": { "company": { "type": "string" }, "ticker": { "type": "string" }, "sector": { "type": "string" }, "shares": { "type": "string" }, "costPerShare": { "type": "string" }, "totalCost": { "type": "string" }, "holdingType": { "type": "string" }, "website": { "type": "string" }, "mediaPress": { "type": "string" }, "currencyExposure": { "type": "string" } }, "required": ["company", "ticker"] }
        },
        {
            "name": "delete-portfolio-holding",
            "description": "Delete a holding from the portfolio by ticker symbol.",
            "parameters": { "type": "object", "properties": { "ticker": { "type": "string" } }, "required": ["ticker"] }
        },
        {
            "name": "mark-as-reviewed",
            "description": "Mark a company as reviewed by ticker symbol.",
            "parameters": { "type": "object", "properties": { "ticker": { "type": "string" } }, "required": ["ticker"] }
        },
        {
            "name": "migrate-from-excel",
            "description": "One-time migration of portfolio data from AlphaAnalyzer-Portfolio.xlsx on SharePoint into Dataverse.",
            "parameters": { "type": "object", "properties": { "source": { "type": "string" } }, "required": ["source"] }
        }
    ],
    "runtimes": [
        {
            "type": "RemoteMCPServer",
            "run_for_functions": ["read-portfolio", "update-portfolio-holding", "add-portfolio-holding", "delete-portfolio-holding", "mark-as-reviewed", "migrate-from-excel"],
            "spec": {
                "url": "${{PORTFOLIO_MCP_ENDPOINT}}",
                "x-mcp_tool_description": {
                    "tools": [
                        { "name": "read-portfolio", "description": "Read portfolio holdings from Dataverse.", "inputSchema": { "type": "object", "properties": { "filter": { "type": "string", "description": "'active', 'prospects', or ticker symbol" } } }, "annotations": { "readOnlyHint": true } },
                        { "name": "update-portfolio-holding", "description": "Update a holding by ticker. Specify only fields to change.", "inputSchema": { "type": "object", "properties": { "ticker": { "type": "string" }, "shares": { "type": "string" }, "costPerShare": { "type": "string" }, "totalCost": { "type": "string" }, "sector": { "type": "string" }, "holdingType": { "type": "string" }, "website": { "type": "string" }, "mediaPress": { "type": "string" }, "currencyExposure": { "type": "string" }, "fxHedged": { "type": "string" }, "revenueAttributed": { "type": "string" }, "marginPercent": { "type": "string" } }, "required": ["ticker"] } },
                        { "name": "add-portfolio-holding", "description": "Add a new holding. Requires company and ticker.", "inputSchema": { "type": "object", "properties": { "company": { "type": "string" }, "ticker": { "type": "string" }, "sector": { "type": "string" }, "shares": { "type": "string" }, "costPerShare": { "type": "string" }, "totalCost": { "type": "string" }, "holdingType": { "type": "string" }, "website": { "type": "string" }, "mediaPress": { "type": "string" }, "currencyExposure": { "type": "string" } }, "required": ["company", "ticker"] } },
                        { "name": "delete-portfolio-holding", "description": "Delete a holding by ticker.", "inputSchema": { "type": "object", "properties": { "ticker": { "type": "string" } }, "required": ["ticker"] } },
                        { "name": "mark-as-reviewed", "description": "Mark as reviewed by ticker.", "inputSchema": { "type": "object", "properties": { "ticker": { "type": "string" } }, "required": ["ticker"] } },
                        { "name": "migrate-from-excel", "description": "Migrate from Excel to Dataverse.", "inputSchema": { "type": "object", "properties": { "source": { "type": "string" } }, "required": ["source"] } }
                    ]
                }
            },
            "auth": { "type": "None" }
        }
    ]
}
