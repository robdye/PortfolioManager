{
  "name": "portfolio-agent-mcp",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Portfolio Agent MCP Server — Finnhub market data with interactive UI widgets for M365 Copilot",
  "scripts": {
    "build:widgets": "node widgets/build.mjs",
    "start": "node --env-file=.env --import tsx src/index.ts",
    "dev": "node --env-file=.env --import tsx --watch src/index.ts",
    "inspector": "npx @modelcontextprotocol/inspector",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^25.6.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  }
}
